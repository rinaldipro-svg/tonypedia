---
import { formatDate, getReadingTime } from '../utils/helpers';
import type { CollectionEntry } from 'astro:content';
import { CATEGORIES } from '../utils/categories';

interface Props {
  articles: CollectionEntry<'articles'>[];
}

const { articles } = Astro.props;

const totalArticles = articles.length;

const uniqueCategories = new Set(articles.map(a => a.data.category)).size;

const latestDate = articles.length > 0
  ? articles.reduce((latest, article) => {
      return article.data.pubDate > latest.data.pubDate ? article : latest;
    }, articles[0]).data.pubDate
  : new Date();

const totalReadingTime = articles.reduce((sum, article) => {
  const readingTime = article.data.readingTime || getReadingTime(article.body || '');
  return sum + readingTime;
}, 0);
---

<section class="max-w-6xl mx-auto px-6 py-12 md:py-16">
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <!-- Total Articles -->
    <div class="glass-card p-6">
      <div class="text-3xl mb-2">📚</div>
      <div class="text-3xl font-heading font-bold text-white mb-1">
        {totalArticles}
      </div>
      <div class="text-sm text-gray-400">
        Total Articles
      </div>
    </div>

    <!-- Active Categories -->
    <div class="glass-card p-6">
      <div class="text-3xl mb-2">🏷️</div>
      <div class="text-3xl font-heading font-bold text-white mb-1">
        {uniqueCategories}
      </div>
      <div class="text-sm text-gray-400">
        Categories
      </div>
    </div>

    <!-- Latest Update -->
    <div class="glass-card p-6">
      <div class="text-3xl mb-2">📅</div>
      <div class="text-lg font-heading font-bold text-white mb-1">
        {formatDate(latestDate)}
      </div>
      <div class="text-sm text-gray-400">
        Latest Update
      </div>
    </div>

    <!-- Total Reading Time -->
    <div class="glass-card p-6">
      <div class="text-3xl mb-2">⏱️</div>
      <div class="text-3xl font-heading font-bold text-white mb-1">
        {totalReadingTime}
      </div>
      <div class="text-sm text-gray-400">
        Hours to Read
      </div>
    </div>
  </div>
</section>
