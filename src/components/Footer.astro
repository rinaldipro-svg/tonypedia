---
import { CATEGORIES } from '../utils/categories';

---

<footer class="bg-navy-900 border-t border-white/10 py-12 md:py-16 px-6">
  <div class="max-w-6xl mx-auto">
    <!-- Main Footer Content -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      <!-- About Section -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <span class="text-blue-500 text-2xl font-bold">●</span>
          <span class="font-heading font-bold text-xl">Tonypedia</span>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed">
          Your World, Explained. A curated knowledge hub covering technology,
          geopolitics, culture, and beyond.
        </p>
      </div>

      <!-- Categories -->
      <div>
        <h3 class="font-heading font-bold text-white mb-6">Explore</h3>
        <ul class="space-y-3">
          {
            Object.entries(CATEGORIES).map(([key, { label, icon }]) => (
              <li>
                <a
                  href={`/category/${key}`}
                  class="text-gray-400 hover:text-white transition-colors duration-200 text-sm flex items-center gap-2"
                >
                  <span>{icon}</span>
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h3 class="font-heading font-bold text-white mb-6">Connect</h3>
        <ul class="space-y-3">
          <li>
            <a
              href="#"
              class="text-gray-400 hover:text-white transition-colors duration-200 text-sm"
              target="_blank"
              rel="noopener noreferrer"
            >
              Twitter/X
            </a>
          </li>
          <li>
            <a
              href="#"
              class="text-gray-400 hover:text-white transition-colors duration-200 text-sm"
              target="_blank"
              rel="noopener noreferrer"
            >
              LinkedIn
            </a>
          </li>
          <li>
            <a
              href="#"
              class="text-gray-400 hover:text-white transition-colors duration-200 text-sm"
              target="_blank"
              rel="noopener noreferrer"
            >
              GitHub
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-gray-500 text-sm">
        © 2025 Tonypedia. All rights reserved.
      </p>
      <p class="text-gray-500 text-sm">
        Powered by <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-blue-400 hover:text-blue-300">Astro</a> + <a href="https://pages.cloudflare.com" target="_blank" rel="noopener noreferrer" class="text-blue-400 hover:text-blue-300">Cloudflare Pages</a>
      </p>
    </div>
  </div>

  <style>
    html.light {
      @apply bg-white border-gray-200;
    }
  </style>
</footer>
