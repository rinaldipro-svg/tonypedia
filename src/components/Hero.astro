---
import { formatDate, getReadingTime } from '../utils/helpers';
import TagBadge from './TagBadge.astro';
import type { CategoryKey } from '../utils/categories';

interface Props {
  title: string;
  description: string;
  category: CategoryKey;
  pubDate: Date;
  slug: string;
  heroImage?: string;
  readingTime?: number;
  body?: string;
}

const {
  title,
  description,
  category,
  pubDate,
  slug,
  heroImage,
  readingTime,
  body = '',
} = Astro.props;

const estimatedReadingTime = readingTime || getReadingTime(body);
---

<section
  class="relative min-h-[70vh] md:min-h-screen flex items-center justify-center overflow-hidden"
  style={heroImage ? `background-image: linear-gradient(135deg, rgba(10,15,30,0.8) 0%, rgba(31,41,55,0.6) 100%), url('${heroImage}'); background-size: cover; background-position: center;` : 'background: linear-gradient(135deg, #0a0f1e 0%, #1f2937 100%);'}
>
  <div class="absolute inset-0 bg-gradient-to-b from-navy-900 via-navy-900/60 to-transparent pointer-events-none"></div>
  
  <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
    <TagBadge category={category} className="justify-center mx-auto mb-6" />
    
    <h1 class="font-heading font-bold text-4xl md:text-6xl text-white mb-6 leading-tight text-balance">
      {title}
    </h1>
    
    <p class="text-lg text-gray-300 max-w-2xl mx-auto mb-8 leading-relaxed">
      {description}
    </p>
    
    <div class="flex items-center justify-center gap-4 text-sm text-gray-400 mb-8">
      <span>{estimatedReadingTime} min read</span>
      <span>•</span>
      <span>{formatDate(pubDate)}</span>
    </div>
    
    <a
      href={`/articles/${slug}`}
      class="inline-block px-8 py-3 bg-blue-500 hover:bg-blue-600 text-white font-semibold rounded-lg transition-colors duration-200"
    >
      Read Article →
    </a>
  </div>
</section>
