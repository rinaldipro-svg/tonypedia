---
import BaseLayout from './BaseLayout.astro';
import { formatDate } from '../utils/helpers';
import TagBadge from '../components/TagBadge.astro';
import type { CollectionEntry } from 'astro:content';
import type { CategoryKey } from '../utils/categories';

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { title, description, author, pubDate, category, tags, heroImage, readingTime: rt, body } = article.data;

const getReadingTime = (text: string) => {
  const wordsPerMinute = 200;
  const words = text.trim().split(/\s+/).length;
  return Math.ceil(words / wordsPerMinute);
};

const readingTime = rt || getReadingTime(body || '');

const currentUrl = new URL(Astro.request.url).href;
const shareUrl = encodeURIComponent(currentUrl);
const shareTitle = encodeURIComponent(title);
---

<BaseLayout title={title} description={description} ogImage={heroImage}>
  <article class="max-w-3xl mx-auto px-6 py-12 md:py-16">
    <!-- Article Header -->
    <header class="mb-12">
      <TagBadge category={category as CategoryKey} className="mb-4" />

      <h1 class="font-heading font-bold text-4xl md:text-5xl text-white mb-6 leading-tight">
        {title}
      </h1>

      <p class="text-xl text-gray-300 mb-6 leading-relaxed">
        {description}
      </p>

      <div class="flex flex-col md:flex-row md:items-center md:gap-8 pb-6 border-b border-white/10">
        <div class="flex items-center gap-4 text-sm text-gray-400">
          <span>By {author}</span>
          <span>•</span>
          <span>{formatDate(pubDate)}</span>
          <span>•</span>
          <span>{readingTime} min read</span>
        </div>
      </div>

      <!-- Share Buttons -->
      <div class="mt-6 flex items-center gap-4">
        <span class="text-sm text-gray-400">Share:</span>
        <a
          href={`https://x.com/intent/tweet?text=${shareTitle}&url=${shareUrl}`}
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-400 hover:text-blue-400 transition-colors duration-200"
          aria-label="Share on X"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path d="M12.6 1H3.4C2.227 1 1 2.2 1 3.4v13.2C1 17.8 2.2 19 3.4 19h13.2c1.16 0 2.4-1.2 2.4-2.4V3.4C19 2.227 17.8 1 16.6 1zm-1.16 13.4h-2.52V7.2h2.52v7.2zM8.22 6.36c-.72 0-1.28-.65-1.28-1.38C6.94 4.3 7.5 3.6 8.22 3.6c.72 0 1.28.64 1.28 1.38 0 .73-.56 1.38-1.28 1.38zm9.82 7.04h-2.52v-3.9c0-.92-.4-1.55-1.2-1.55-.68 0-1.08.48-1.26.96-.08.16-.08.38-.08.6v3.89h-2.52V7.2h2.52v.96c.35-.52.96-1.28 2.37-1.28 1.72 0 3.01 1.13 3.01 3.58v3.9z"></path>
          </svg>
        </a>
        <button
          id="copy-link-btn"
          class="text-gray-400 hover:text-blue-400 transition-colors duration-200"
          aria-label="Copy link"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.658 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
          </svg>
        </button>
      </div>
    </header>

    <!-- Hero Image -->
    {
      heroImage && (
        <img
          src={heroImage}
          alt={title}
          class="w-full h-96 object-cover rounded-2xl mb-12 shadow-lg"
          loading="lazy"
        />
      )
    }

    <!-- Article Body -->
    <div class="prose prose-invert prose-lg max-w-full mb-12">
      <slot />
    </div>

    <!-- Tags -->
    {
      tags.length > 0 && (
        <div class="border-t border-white/10 pt-8 mb-8">
          <p class="text-sm text-gray-400 mb-4">Tags:</p>
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <a
                href={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`}
                class="px-3 py-1 bg-white/10 hover:bg-white/20 text-gray-300 hover:text-white rounded-full text-sm transition-colors duration-200"
              >
                #{tag}
              </a>
            ))}
          </div>
        </div>
      )
    }

    <!-- Related Articles -->
    <div class="border-t border-white/10 pt-8">
      <h2 class="font-heading font-bold text-2xl text-white mb-6">Related Articles</h2>
      <div id="related-articles-placeholder">
        <p class="text-gray-400">Loading related articles...</p>
      </div>
    </div>
  </article>
</BaseLayout>

<script define:vars={{ currentUrl }}>
  async function copyLink() {
    try {
      await navigator.clipboard.writeText(currentUrl);
      const btn = document.getElementById('copy-link-btn');
      if (btn) {
        const originalHTML = btn.innerHTML;
        btn.innerHTML = '✓ Copied!';
        setTimeout(() => {
          btn.innerHTML = originalHTML;
        }, 2000);
      }
    } catch (err) {
      console.error('Failed to copy link:', err);
    }
  }

  document.getElementById('copy-link-btn')?.addEventListener('click', copyLink);
</script>
