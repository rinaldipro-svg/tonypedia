---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);

  const tags = new Set<string>();
  articles.forEach((article) => {
    article.data.tags.forEach((tag) => {
      tags.add(tag.toLowerCase().replace(/\s+/g, '-'));
    });
  });

  return Array.from(tags).map((tag) => ({
    params: { tag },
  }));
}

const { tag } = Astro.params;

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const tagArticles = allArticles
  .filter((a) =>
    a.data.tags.some((t) => t.toLowerCase().replace(/\s+/g, '-') === tag)
  )
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const displayTag = tagArticles.length > 0 
  ? tagArticles[0].data.tags.find((t) => t.toLowerCase().replace(/\s+/g, '-') === tag)
  : tag;
---

<BaseLayout
  title={`#${displayTag} | Tonypedia`}
  description={`Articles tagged with ${tag} on Tonypedia.`}
>
  <div class="max-w-6xl mx-auto px-6 py-12 md:py-16">
    <div class="mb-12">
      <h1 class="font-heading font-bold text-4xl md:text-5xl text-white mb-2">
        #{displayTag}
      </h1>
      <p class="text-gray-400">
        {tagArticles.length} article{tagArticles.length !== 1 ? 's' : ''}
      </p>
    </div>

    {
      tagArticles.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {tagArticles.map((article) => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              category={article.data.category}
              pubDate={article.data.pubDate}
              slug={article.slug}
              heroImage={article.data.heroImage}
              readingTime={article.data.readingTime}
              body={article.body}
            />
          ))}
        </div>
      ) : (
        <div class="glass-card p-12 text-center">
          <h2 class="font-heading font-semibold text-xl text-gray-300 mb-2">
            No articles found
          </h2>
          <p class="text-gray-400">
            No articles are tagged with #{tag}.
          </p>
        </div>
      )
    }
  </div>
</BaseLayout>
